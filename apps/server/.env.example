# Port the Socket.IO server listens on (Railway/Render set this automatically).
PORT=4000
# Allowed web origin for CORS / Socket.IO (the Next.js app).
# Local: http://localhost:3000
# Prod:  set on Railway/Render → your Vercel URL, e.g. https://wordspy.vercel.app
#        (must match exactly; preview deploys won't match). See DEPLOY.md.
WEB_ORIGIN=http://localhost:3000
