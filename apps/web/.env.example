# Absolute URL of the Socket.IO server (NOT same-origin — server runs on
# Railway/Render, frontend on Vercel). Required at build + runtime.
# Local:  http://localhost:4000
# Prod:   set in Vercel → e.g. https://wordspy-server.up.railway.app
#         (baked in at build time — set before deploying). See DEPLOY.md.
NEXT_PUBLIC_SOCKET_URL=http://localhost:4000
