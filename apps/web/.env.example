# Absolute URL of the Socket.IO server (NOT same-origin — server runs on
# Railway/Render, frontend on Vercel). Required at build + runtime.
# Local:  http://localhost:4000
# Prod:   set in Vercel → e.g. https://wordspy-server.up.railway.app
#         (baked in at build time — set before deploying). See DEPLOY.md.
NEXT_PUBLIC_SOCKET_URL=http://localhost:4000

# Resend API key for the "Report an issue" form (server-side, NOT public).
# Get one at https://resend.com. To send to arbitrary inboxes you need a
# verified domain (set REPORT_FROM to it); resend.dev only reaches the account owner.
RESEND_API_KEY=re_Gp4fYDUn_3qJkEJUV9h5P1tVP4T2iH18z
# Optional verified sender, e.g. "wordspy <reports@yourdomain.com>"
REPORT_FROM=harishtaskar001@gmail.com
